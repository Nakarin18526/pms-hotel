{
  "name": "pms",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @pms/api prisma generate",
    "db:migrate": "pnpm --filter @pms/api prisma migrate dev",
    "db:seed": "pnpm --filter @pms/api db:seed",
    "db:studio": "pnpm --filter @pms/api prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  }
}
