# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pms?schema=public"

# --- Currency / Locale ---
CURRENCY=THB
TIMEZONE=Asia/Bangkok

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000

# --- NextAuth (apps/web) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# --- JWT shared between web & api (must match NEXTAUTH_SECRET) ---
JWT_SECRET=replace-with-openssl-rand-base64-32

# --- Google OAuth (Guest) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="PMS <noreply@example.com>"
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
